---
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: "{{ kind_cluster_name }}"
nodes:
  - role: control-plane
    image: "{{ kind_k8s_image }}"
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
  - role: worker
    image: "{{ kind_k8s_image }}"
  - role: worker
    image: "{{ kind_k8s_image }}"
